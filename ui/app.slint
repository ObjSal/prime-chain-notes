import { Theme, UISize, ButtonStyleProps, ButtonSizeProps, ButtonVariant, ButtonState, ButtonSize } from "@ui/theme.slint";
import { Callbacks, Ui, Home, Compose, Confirm, Notes, NoteRow, View, Sync, SignPsbt, Settings, Contacts, ContactRow, Coins, CoinRow, Sweep, NotebooksUi, NotebookCb, NotebookRow, SenderRow, Recovery, ExportNbRow, Funding, FundingCoinRow, ChangePick } from "callbacks.slint";
import { Button } from "@ui/button.slint";

export { Callbacks, Ui, Home, Compose, Confirm, Notes, View, Sync, SignPsbt, Settings, Contacts, Coins, Sweep, NotebooksUi, NotebookCb, Recovery, Funding, ChangePick, Theme, ButtonStyleProps, ButtonSizeProps, ButtonVariant, ButtonState, ButtonSize }

component PrimaryAction inherits Button {
    background: Theme.palette-primary;
    foreground: #ffffff;
    border-color: transparent;
    border-width: 0px;
    font-weight: 600;
    font-family: "Montserrat";
    button-opacity: self.disabled ? 0.5 : 1.0;
    touch-expansion: 4px;
    font-size: 20px;
    padding-horizontal: 20px;
    padding-vertical: 12px;
    border-radius: 24px;
}

component SecondaryAction inherits Button {
    background: Theme.palette-surface;
    foreground: Theme.palette-foreground;
    border-color: Theme.palette-border;
    border-width: 1px;
    font-weight: 600;
    font-family: "Montserrat";
    touch-expansion: 4px;
    font-size: 20px;
    padding-horizontal: 20px;
    padding-vertical: 12px;
    border-radius: 24px;
}

// Plain-TouchArea back control — the SDK IconButton drops taps (sibling
// apps' NOTES), so headers use text buttons.
component BackBtn inherits TouchArea {
    width: 90px;
    height: 40px;
    callback back();
    clicked => { root.back(); }
    Text {
        text: "‹ Back";
        color: Theme.palette-primary;
        font-family: "Montserrat";
        font-size: 20px;
        font-weight: 600;
        vertical-alignment: center;
    }
}

component ScreenHeader inherits Rectangle {
    in property <string> title;
    in property <bool> show-back: true;
    callback back();
    height: 48px;
    if root.show-back: BackBtn {
        x: 0;
        y: 4px;
        back => { root.back(); }
    }
    Text {
        text: root.title;
        color: Theme.palette-foreground;
        font-family: "Montserrat";
        font-size: 22px;
        font-weight: 700;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

// Two-state pill toggle (Private / Public, fee tiers).
component PillOption inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback tapped();
    height: 44px;
    border-radius: 22px;
    background: selected ? Theme.palette-primary : Theme.palette-surface;
    border-width: 1px;
    border-color: selected ? Theme.palette-primary : Theme.palette-border;
    TouchArea { clicked => { root.tapped(); } }
    Text {
        text: root.label;
        color: root.selected ? #ffffff : Theme.palette-foreground;
        font-family: "Montserrat";
        font-size: 17px;
        font-weight: 600;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
}

// Scrollable multiline editor: Flickable around a builtin TextInput with
// cursor-follow (text-editor pattern — the SDK TextArea can't scroll).
component EditorField inherits Rectangle {
    in-out property <string> text;
    in property <string> placeholder;
    out property <bool> has-focus: input.has-focus;
    callback changed();
    forward-focus: input;

    property <length> pad: 14px;

    background: Theme.palette-surface;
    border-radius: 16px;
    border-width: 1px;
    border-color: input.has-focus ? Theme.palette-primary : Theme.palette-border;
    clip: true;

    fly := Flickable {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        height: parent.height - 2 * root.pad;
        viewport-width: self.width;
        viewport-height: max(self.height, input.preferred-height);

        input := TextInput {
            width: parent.width;
            text <=> root.text;
            color: Theme.palette-foreground;
            font-family: "SourceCodePro";
            font-size: 18px;
            single-line: false;
            wrap: word-wrap;
            vertical-alignment: top;
            page-height: fly.height;
            edited => { root.changed(); }
            cursor-position-changed(cpos) => {
                if (cpos.y + fly.viewport-y < 12px) {
                    fly.viewport-y = min(0px, max(fly.height - self.height, -cpos.y + 12px));
                } else if (cpos.y + fly.viewport-y > fly.height - 36px) {
                    fly.viewport-y = min(0px, max(fly.height - self.height, fly.height - cpos.y - 36px));
                }
            }
        }
    }

    Text {
        x: root.pad;
        y: root.pad;
        width: parent.width - 2 * root.pad;
        text: root.text == "" && input.preedit-text == "" ? root.placeholder : "";
        color: Theme.palette-muted;
        font-family: "SourceCodePro";
        font-size: 18px;
        wrap: word-wrap;
    }
}

component NoteEntry inherits Rectangle {
    in property <NoteRow> entry;
    callback tapped();
    height: 76px;
    border-radius: 12px;
    background: touch.has-hover ? Theme.palette-surface : transparent;
    border-width: 1px;
    border-color: Theme.palette-border;
    touch := TouchArea { clicked => { root.tapped(); } }
    VerticalLayout {
        padding: 10px;
        spacing: 4px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.entry.preview;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 18px;
                font-weight: 600;
                overflow: elide;
                horizontal-stretch: 1;
            }
            Text {
                text: root.entry.badge;
                color: root.entry.badge == "PRIVATE" ? Theme.palette-primary : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
        Text {
            text: root.entry.meta;
            color: Theme.palette-muted;
            font-family: "SourceCodePro";
            font-size: 14px;
            overflow: elide;
        }
    }
}

// One coin on the Pay-from screen: an ASCII [x]/[  ] checkbox row (device
// font tofus fancy glyphs — same convention as the Notes sender filter).
component FundingCoinEntry inherits Rectangle {
    in property <FundingCoinRow> entry;
    callback tapped();
    height: 48px;
    border-radius: 10px;
    border-width: 1px;
    border-color: Theme.palette-border;
    TouchArea { clicked => { root.tapped(); } }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 12px;
        spacing: 8px;
        Rectangle {
            width: 26px;
            Text {
                text: root.entry.selected ? "[x]" : "[  ]";
                color: root.entry.selected ? Theme.palette-primary : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 700;
                x: 0;
                y: (parent.height - self.height) / 2;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.entry.label;
                color: root.entry.selected ? Theme.palette-foreground : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.entry.meta;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 12px;
                overflow: elide;
            }
        }
    }
}

// A single-select destination row on the Change screen: ASCII (x)/( )
// radio marker, matching FundingCoinEntry's checkbox convention.
component ChangeOptionRow inherits Rectangle {
    in property <string> option-label;
    in property <string> sub;
    in property <bool> selected;
    callback tapped();
    height: sub == "" ? 44px : 66px;
    border-radius: 10px;
    border-width: 1px;
    border-color: root.selected ? Theme.palette-primary : Theme.palette-border;
    TouchArea { clicked => { root.tapped(); } }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 12px;
        spacing: 8px;
        Rectangle {
            width: 26px;
            Text {
                text: root.selected ? "(x)" : "(  )";
                color: root.selected ? Theme.palette-primary : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 700;
                x: 0;
                y: (parent.height - self.height) / 2;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            padding-top: 8px;
            padding-bottom: 8px;
            Text {
                text: root.option-label;
                color: root.selected ? Theme.palette-foreground : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
                overflow: elide;
            }
            if root.sub != "": Text {
                text: root.sub;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }
}

// Contact row for the send-to picker: main tap picks, the right "name"
// zone toggles rename mode (its later-declared TouchArea wins the zone).
component ContactEntry inherits Rectangle {
    in property <ContactRow> entry;
    callback tapped();
    callback rename();
    height: 64px;
    border-radius: 12px;
    background: touch.has-hover ? Theme.palette-surface : transparent;
    border-width: 1px;
    border-color: Theme.palette-border;
    touch := TouchArea { clicked => { root.tapped(); } }
    HorizontalLayout {
        padding: 10px;
        spacing: 8px;
        VerticalLayout {
            spacing: 4px;
            horizontal-stretch: 1;
            Text {
                text: root.entry.label;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 18px;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.entry.meta;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 13px;
                overflow: elide;
            }
        }
        Rectangle {
            width: 58px;
            border-radius: 10px;
            background: rename-touch.has-hover ? Theme.palette-border : transparent;
            Text {
                text: "name";
                color: Theme.palette-primary;
                font-family: "Montserrat";
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
            rename-touch := TouchArea { clicked => { root.rename(); } }
        }
    }
}

export component AppWindow inherits Window {
    title: "Chain Notes";
    preferred-width: 480px;
    preferred-height: 800px;
    background: Theme.palette-background;

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: Theme.palette-background;

        // ------------------------------------------------ screen 0: home
        // A NOTEBOOK's home (its address, notes, compose). The header back
        // returns to the notebook list (screen 20 — the main screen).
        if Ui.screen == 0: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            ScreenHeader {
                title: NotebooksUi.title;
                back => { Callbacks.refresh-home(); NotebookCb.back-to-list(); }
            }

            if Home.address == "": Text {
                text: Ui.error == "" ? "Deriving identity…" : Ui.error;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 17px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }

            if Home.address != "": VerticalLayout {
                spacing: 10px;
                Image {
                    source: Home.qr;
                    width: 190px;
                    height: 190px;
                    image-rendering: pixelated;
                    x: (parent.width - self.width) / 2;
                }
                Text {
                    text: Home.address;
                    color: Theme.palette-muted;
                    font-family: "SourceCodePro";
                    font-size: 13px;
                    wrap: char-wrap;
                    horizontal-alignment: center;
                }
                Text {
                    text: Home.balance-line;
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 20px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
                Text {
                    text: Home.sync-line + " · " + Home.network;
                    color: Theme.palette-muted;
                    font-family: "SourceCodePro";
                    font-size: 14px;
                    horizontal-alignment: center;
                }
            }

            Rectangle { vertical-stretch: 1; }

            PrimaryAction {
                width: 100%;
                text: "Compose note";
                disabled: Home.address == "";
                clicked => {
                    Contacts.pick-mode = "compose";
                    Callbacks.refresh-contacts();
                    Ui.screen = 7;
                }
            }
            SecondaryAction {
                width: 100%;
                text: "Notes";
                clicked => {
                    Callbacks.refresh-notes();
                    Ui.screen = 1;
                }
            }
            SecondaryAction {
                width: 100%;
                text: "Sync";
                clicked => { Ui.screen = 5; }
            }
            // No Settings here — it is wallet-level (network, chunk, wallet
            // coins/sweep), reachable from the notebook list.
        }

        // ------------------------------------------- screen 1: notes list
        if Ui.screen == 1: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            ScreenHeader {
                title: "Notes";
                back => { Callbacks.refresh-home(); Ui.screen = 0; }
            }

            if Notes.rows.length == 0 && Notes.hidden-label == "": Text {
                text: "No notes yet.\nCompose one, or import a sync bundle.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 17px;
                horizontal-alignment: center;
            }

            // Sender filter: tap the row to expand a per-sender checklist;
            // the warn pill flags a persisted exclusion so hidden notes are
            // never a silent mystery.
            if Notes.senders.length > 1: Rectangle {
                height: 32px;
                TouchArea { clicked => { Notes.filter-expanded = !Notes.filter-expanded; } }
                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: Notes.hidden-label == "" ? "All senders" : Notes.hidden-label;
                        color: Notes.hidden-label == "" ? Theme.palette-muted : Theme.palette-primary;
                        font-family: "Montserrat";
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: "Senders " + (Notes.filter-expanded ? " ^" : " v");
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                }
            }
            if Notes.filter-expanded: Flickable {
                height: min(Notes.senders.length * 44px, 176px);
                viewport-height: Notes.senders.length * 44px;
                VerticalLayout {
                    spacing: 4px;
                    for s in Notes.senders: Rectangle {
                        height: 40px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: Theme.palette-border;
                        TouchArea { clicked => { Callbacks.toggle-sender(s.key, !s.excluded); } }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 12px;
                            spacing: 8px;
                            Rectangle {
                                width: 22px;
                                Text {
                                    text: s.excluded ? "[  ]" : "[x]";
                                    color: s.excluded ? Theme.palette-muted : Theme.palette-primary;
                                    font-family: "Montserrat";
                                    font-size: 15px;
                                    font-weight: 700;
                                    x: 0; y: (parent.height - self.height) / 2;
                                }
                            }
                            Text {
                                text: s.label;
                                color: s.excluded ? Theme.palette-muted : Theme.palette-foreground;
                                font-family: "Montserrat";
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            Text {
                                text: s.sub;
                                color: Theme.palette-muted;
                                font-family: "Montserrat";
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: Notes.rows.length * 84px;
                VerticalLayout {
                    spacing: 8px;
                    for entry in Notes.rows: NoteEntry {
                        entry: entry;
                        tapped => { Callbacks.open-note(entry.id); }
                    }
                }
            }
        }

        // -------------------------------------------- screen 2: note view
        if Ui.screen == 2: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            ScreenHeader {
                title: "Note";
                back => { Callbacks.refresh-notes(); Ui.screen = 1; }
            }

            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: View.badge;
                    color: View.badge == "PRIVATE" ? Theme.palette-primary : Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 14px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                if View.has-qr: PillOption {
                    width: 130px;
                    label: View.show-qr ? "Show text" : "Show tx QR";
                    selected: View.show-qr;
                    tapped => { View.show-qr = !View.show-qr; }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: Theme.palette-surface;
                border-radius: 16px;
                clip: true;
                if !View.show-qr: Flickable {
                    x: 14px; y: 14px;
                    width: parent.width - 28px;
                    height: parent.height - 28px;
                    viewport-width: self.width;
                    viewport-height: max(self.height, body.preferred-height);
                    body := Text {
                        width: parent.width;
                        text: View.text;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 18px;
                        wrap: word-wrap;
                    }
                }
                if View.show-qr: VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    // Plain Rectangle parent: layouts ignore a child's x/y,
                    // so centering math must live one level down.
                    Rectangle {
                        vertical-stretch: 1;
                        Image {
                            source: View.qr;
                            width: min(parent.width, parent.height, 360px);
                            height: self.width;
                            image-rendering: pixelated;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    Text {
                        text: "Scan with the companion's “Scan from device” to broadcast.";
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 13px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                }
            }

            Text {
                text: View.meta;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 13px;
                wrap: char-wrap;
            }
        }

        // ---------------------------------------------- screen 3: compose
        // Everything interactive stays in the top ~400px so the on-screen
        // keyboard never covers a control (sibling-app gotcha).
        if Ui.screen == 3: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 8px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                vertical-stretch: 0;
                title: "Compose";
                // Back to the picker so the recipient can be changed
                // without losing the draft (Compose.text persists).
                back => { Callbacks.refresh-contacts(); Ui.screen = 7; }
            }

            // Who this note goes to — set by the contacts picker; compose
            // itself has no address editing.
            Text {
                vertical-stretch: 0;
                text: Compose.to-label;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 14px;
                overflow: elide;
            }

            // Pay-from (funding-unification): who funds this note —
            // notebook, spending wallet, or a mix. Compact nav row, like
            // the gift panel's header, opening the picker (screen 25).
            Rectangle {
                vertical-stretch: 0;
                height: 34px;
                TouchArea { clicked => { Callbacks.funding-open(); Ui.screen = 25; } }
                HorizontalLayout {
                    Text {
                        text: "Pay from · " + Compose.pay-from-label;
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: Compose.pay-from-balance + "  ›";
                        color: Theme.palette-muted;
                        font-family: "SourceCodePro";
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }
            }
            // Change destination (screen 26).
            Rectangle {
                vertical-stretch: 0;
                height: 30px;
                TouchArea { clicked => { Callbacks.change-open(); Ui.screen = 26; } }
                HorizontalLayout {
                    Text {
                        text: "Change · " + Compose.change-label;
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 13px;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: "›";
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 13px;
                        vertical-alignment: center;
                    }
                }
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                PillOption {
                    label: "Private";
                    selected: Compose.private-note;
                    horizontal-stretch: 1;
                    tapped => { Compose.private-note = true; Callbacks.compose-changed(); }
                }
                PillOption {
                    label: "Public";
                    selected: !Compose.private-note;
                    horizontal-stretch: 1;
                    tapped => { Compose.private-note = false; Callbacks.compose-changed(); }
                }
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 6px;
                PillOption {
                    label: "Economy";
                    selected: Compose.tier == 0;
                    horizontal-stretch: 1;
                    tapped => { Compose.tier = 0; Callbacks.compose-changed(); }
                }
                PillOption {
                    label: "Normal";
                    selected: Compose.tier == 1;
                    horizontal-stretch: 1;
                    tapped => { Compose.tier = 1; Callbacks.compose-changed(); }
                }
                PillOption {
                    label: "Fast";
                    selected: Compose.tier == 2;
                    horizontal-stretch: 1;
                    tapped => { Compose.tier = 2; Callbacks.compose-changed(); }
                }
                PillOption {
                    label: "Custom";
                    selected: Compose.tier == 3;
                    horizontal-stretch: 1;
                    tapped => { Compose.tier = 3; Callbacks.compose-changed(); }
                }
            }

            // Custom fee-rate field — revealed ONLY when the Custom tier is
            // selected (tapping the pill above is the toggle). The three
            // preset tiers need no field, so it stays out of the way.
            if Compose.tier == 3: HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                Rectangle {
                    height: 44px;
                    horizontal-stretch: 1;
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: rate-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                    clip: true;
                    rate-input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        text <=> Compose.rate-text;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 18px;
                        single-line: true;
                        edited => { Callbacks.compose-changed(); }
                        accepted => { self.clear-focus(); }
                    }
                }
                Text {
                    text: "sat/vB";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 16px;
                    vertical-alignment: center;
                }
            }

            // Gift amount — directed notes only. Collapsible panel (styled
            // like the compose panels): the recipient output carries this
            // many sats instead of the default dust. Default/min = 330.
            if Compose.to-address != "": Rectangle {
                vertical-stretch: 0;
                border-radius: 12px;
                background: Theme.palette-surface;
                border-width: 1px;
                border-color: Theme.palette-border;
                height: gift-col.preferred-height;
                gift-col := VerticalLayout {
                    padding: 10px;
                    spacing: 8px;
                    Rectangle {
                        height: 22px;
                        TouchArea { clicked => { Compose.gift-expanded = !Compose.gift-expanded; } }
                        HorizontalLayout {
                            Text {
                                text: "Gift · \{Compose.gift-sats} sats";
                                color: Theme.palette-muted;
                                font-family: "SourceCodePro";
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                            Rectangle { }
                            Image {
                                source: Compose.gift-expanded
                                    ? @image-url("../resources/icons/chevron-up.svg")
                                    : @image-url("../resources/icons/chevron-down.svg");
                                colorize: Theme.palette-muted;
                                width: 16px;
                                height: 16px;
                                y: (parent.height - 16px) / 2;
                            }
                        }
                    }
                    if Compose.gift-expanded: Text {
                        text: "Sats sent to the recipient with your note. Minimum 330 (dust).";
                        color: Theme.palette-muted;
                        font-family: "SourceCodePro";
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    if Compose.gift-expanded: Rectangle {
                        height: 44px;
                        background: Theme.palette-background;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: gift-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                        clip: true;
                        gift-input := TextInput {
                            x: 14px;
                            width: parent.width - 28px;
                            height: 24px;
                            y: (parent.height - self.height) / 2;
                            text <=> Compose.gift-sats;
                            color: Theme.palette-foreground;
                            font-family: "SourceCodePro";
                            font-size: 18px;
                            single-line: true;
                            input-type: number;
                            edited => { Callbacks.compose-changed(); }
                            accepted => { self.clear-focus(); }
                        }
                    }
                }
            }

            editor := EditorField {
                vertical-stretch: 0;
                // The To row moved to the contacts picker; only a small
                // to-label remains above, so the editor gets its height
                // back while Continue stays above the on-screen keyboard.
                height: 118px;
                text <=> Compose.text;
                placeholder: "Type your note…";
                changed => { Callbacks.compose-changed(); }
                // Keyboard Done: the system keyboard's Done key sends a
                // plain '\n'; Rust strips it and bumps dismiss-nonce —
                // dropping focus here hides the keyboard (IMR Disable).
                property <int> dn: Compose.dismiss-nonce;
                changed dn => { self.clear-focus(); }
            }

            // Live cost readout — updates every keystroke.
            Text {
                vertical-stretch: 0;
                text: Compose.cost-line;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 14px;
                wrap: word-wrap;
            }

            PrimaryAction {
                vertical-stretch: 0;
                width: 100%;
                text: "Continue";
                disabled: !Compose.can-continue;
                clicked => {
                    editor.clear-focus();
                    Callbacks.compose-continue();
                }
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ----------------------------------------- screen 4: confirm-sign
        if Ui.screen == 4: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            ScreenHeader {
                title: "Confirm";
                back => { Ui.screen = 3; }
            }

            Rectangle {
                vertical-stretch: 1;
                background: Theme.palette-surface;
                border-radius: 16px;
                Text {
                    x: 16px; y: 16px;
                    width: parent.width - 32px;
                    text: Confirm.summary;
                    color: Theme.palette-foreground;
                    font-family: "SourceCodePro";
                    font-size: 16px;
                    wrap: word-wrap;
                }
            }

            Text {
                text: "Signing spends real sats and writes this note to the blockchain forever.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 14px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }

            PrimaryAction {
                width: 100%;
                text: "Sign & export";
                clicked => { Callbacks.confirm-sign(); }
            }
        }

        // ------------------------------------------------- screen 5: sync
        if Ui.screen == 5: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            ScreenHeader {
                title: "Sync";
                back => { Sync.picking = false; Callbacks.refresh-home(); Ui.screen = 0; }
            }

            Text {
                text: Sync.status;
                color: Theme.palette-foreground;
                font-family: "SourceCodePro";
                font-size: 15px;
                wrap: word-wrap;
            }

            // Normal actions — hidden while the import picker is open.
            if !Sync.picking: VerticalLayout {
                spacing: 14px;
                PrimaryAction {
                    width: 100%;
                    text: "Import sync bundle";
                    clicked => { Callbacks.list-bundles(); }
                }
                SecondaryAction {
                    width: 100%;
                    text: "Export pending txs";
                    clicked => { Callbacks.export-pending(); }
                }
                SecondaryAction {
                    width: 100%;
                    text: "Scan bundle 📷";
                    clicked => { Callbacks.scan-bundle(); }
                }
                SecondaryAction {
                    width: 100%;
                    text: "Sign external tx ✍";
                    clicked => { Callbacks.sign-psbt(); }
                }
            }

            // Import picker: the actual files found in the inboxes, so the
            // user chooses one (no silent auto-pick). Empty → instructions.
            if Sync.picking: VerticalLayout {
                spacing: 10px;
                Text {
                    text: "Choose a bundle to import";
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 16px;
                    font-weight: 600;
                }
                for b in Sync.bundles: SecondaryAction {
                    width: 100%;
                    text: b.label;
                    clicked => { Callbacks.pick-bundle(b.name, b.loc); }
                }
                if Sync.bundles.length == 0: Text {
                    text: Sync.empty-hint;
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 14px;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    SecondaryAction {
                        horizontal-stretch: 1;
                        text: "Refresh";
                        clicked => { Callbacks.list-bundles(); }
                    }
                    SecondaryAction {
                        horizontal-stretch: 1;
                        text: "Cancel";
                        clicked => { Sync.picking = false; }
                    }
                }
            }

            Text {
                text: Sync.result;
                color: Ui.error == "" ? Theme.palette-muted : Theme.palette-danger;
                font-family: "SourceCodePro";
                font-size: 14px;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }

            Text {
                text: "Bundles: /chain-notes/inbox on Internal or Airlock.\nSigned txs land in /chain-notes/outbox.";
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 13px;
                wrap: word-wrap;
            }
        }

        // -------------------------------------------- screen 8: signed PSBT
        if Ui.screen == 8: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            ScreenHeader {
                title: "Signed";
                back => { Ui.screen = SignPsbt.back-screen; }
            }
            Text {
                text: SignPsbt.summary;
                color: Theme.palette-foreground;
                font-family: "SourceCodePro";
                font-size: 15px;
                wrap: word-wrap;
            }
            if SignPsbt.has-qr: HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 264px;
                    height: 264px;
                    background: #FFFFFF;
                    border-radius: 12px;
                    Image {
                        source: SignPsbt.qr;
                        width: 240px;
                        height: 240px;
                        x: 12px;
                        y: 12px;
                    }
                }
            }
            Text {
                text: "Scan this with the companion or desktop app to broadcast. Also saved to /chain-notes/outbox.";
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 13px;
                wrap: word-wrap;
            }
            Rectangle { vertical-stretch: 1; }
            PrimaryAction {
                width: 100%;
                text: "Done";
                clicked => { Callbacks.refresh-home(); Ui.screen = 0; }
            }
        }

        // ------------------------------------ screen 9: coins (viewer-first)
        // The UTXO ledger as of the last sync bundle. ONE action — the
        // consolidate button on top — opens the shared sweep screen (10).
        if Ui.screen == 9: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            ScreenHeader {
                title: "Wallet coins";
                back => { Ui.screen = 6; }
            }

            Text {
                text: Coins.summary;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 17px;
                font-weight: 600;
            }

            PrimaryAction {
                width: 100%;
                text: "Consolidate wallet…";
                disabled: !Coins.can-consolidate;
                clicked => { Callbacks.consolidate-open(); }
            }

            if !Coins.can-consolidate: Text {
                text: Coins.rows.length == 0
                    ? "No spendable coins anywhere — fund a notebook's address and import a sync bundle."
                    : "Nothing to consolidate — the wallet already holds a single coin.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: Coins.rows.length * 72px;
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    for coin in Coins.rows: Rectangle {
                        height: 64px;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: Theme.palette-border;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 4px;
                            Text {
                                text: coin.label;
                                color: Theme.palette-foreground;
                                font-family: "Montserrat";
                                font-size: 18px;
                                font-weight: 600;
                                overflow: elide;
                            }
                            Text {
                                text: coin.meta;
                                color: Theme.palette-muted;
                                font-family: "SourceCodePro";
                                font-size: 13px;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }

        // ---------------------- screen 10: sweep / consolidate (compose-like)
        // Shared flow: destination line (picker- or self-set), fee tiers with
        // the collapse-on-Custom rate field, read-only inputs summary, live
        // cost line. A sweep spends ALL coins by design — no coin picking.
        if Ui.screen == 10: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 8px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                vertical-stretch: 0;
                title: Sweep.kind == "consolidate" ? "Consolidate" : "Sweep";
                // Sweep: back to the destination picker (still in sweep
                // mode); consolidate: back to the coins list.
                back => {
                    if Sweep.kind == "consolidate" {
                        Callbacks.refresh-coins();
                        Ui.screen = 9;
                    } else {
                        Callbacks.refresh-contacts();
                        Ui.screen = 7;
                    }
                }
            }

            Text {
                vertical-stretch: 0;
                text: Sweep.dest-label;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 14px;
                overflow: elide;
            }

            HorizontalLayout {
                vertical-stretch: 0;
                spacing: 6px;
                PillOption {
                    label: "Economy";
                    selected: Sweep.tier == 0;
                    horizontal-stretch: 1;
                    tapped => { Sweep.tier = 0; Callbacks.sweep-changed(); }
                }
                PillOption {
                    label: "Normal";
                    selected: Sweep.tier == 1;
                    horizontal-stretch: 1;
                    tapped => { Sweep.tier = 1; Callbacks.sweep-changed(); }
                }
                PillOption {
                    label: "Fast";
                    selected: Sweep.tier == 2;
                    horizontal-stretch: 1;
                    tapped => { Sweep.tier = 2; Callbacks.sweep-changed(); }
                }
                PillOption {
                    label: "Custom";
                    selected: Sweep.tier == 3;
                    horizontal-stretch: 1;
                    tapped => { Sweep.tier = 3; Callbacks.sweep-changed(); }
                }
            }

            if Sweep.tier == 3: HorizontalLayout {
                vertical-stretch: 0;
                spacing: 8px;
                Rectangle {
                    height: 44px;
                    horizontal-stretch: 1;
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: sweep-rate-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                    clip: true;
                    sweep-rate-input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        text <=> Sweep.rate-text;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 18px;
                        single-line: true;
                        edited => { Callbacks.sweep-changed(); }
                        accepted => { self.clear-focus(); }
                    }
                }
                Text {
                    text: "sat/vB";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 16px;
                    vertical-alignment: center;
                }
            }

            // Read-only inputs summary — a sweep always spends every coin.
            Rectangle {
                vertical-stretch: 0;
                border-radius: 12px;
                background: Theme.palette-surface;
                border-width: 1px;
                border-color: Theme.palette-border;
                height: 42px;
                Text {
                    x: 14px;
                    width: parent.width - 28px;
                    height: parent.height;
                    text: Sweep.inputs-line;
                    color: Theme.palette-muted;
                    font-family: "SourceCodePro";
                    font-size: 14px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            Text {
                vertical-stretch: 0;
                text: Sweep.cost-line;
                color: Theme.palette-muted;
                font-family: "SourceCodePro";
                font-size: 14px;
                wrap: word-wrap;
            }

            PrimaryAction {
                vertical-stretch: 0;
                width: 100%;
                text: "Continue";
                disabled: !Sweep.can-continue;
                clicked => { Callbacks.sweep-continue(); }
            }

            Rectangle { vertical-stretch: 1; }
        }

        // -------------------------------------------- screen 6: settings
        if Ui.screen == 6: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 0;
            spacing: 14px;

            ScreenHeader {
                title: "Settings";
                back => { Ui.screen = 20; }
            }

            // Settings has grown (Coins/Sweep, chunk, Accounts, the whole
            // Dangerous area) — scroll the body, keep the header fixed.
            Flickable {
                vertical-stretch: 1;
                viewport-width: self.width;
                viewport-height: s6-content.preferred-height;
                s6-content := VerticalLayout {
                    spacing: 14px;
                    padding-bottom: 24px;

                    SecondaryAction {
                        width: 100%;
                        text: "Network: " + Home.network;
                        clicked => { Callbacks.cycle-network(); }
                    }

            // Funds — viewer-first Coins (consolidate lives there) and the
            // sweep flow (destination picked first, compose-like screen).
            HorizontalLayout {
                spacing: 8px;
                SecondaryAction {
                    horizontal-stretch: 1;
                    text: "Coins";
                    clicked => {
                        Callbacks.refresh-coins();
                        Ui.screen = 9;
                    }
                }
                SecondaryAction {
                    horizontal-stretch: 1;
                    text: "Sweep funds…";
                    disabled: Home.address == "";
                    clicked => {
                        Contacts.pick-mode = "sweep";
                        Callbacks.refresh-contacts();
                        Ui.screen = 7;
                    }
                }
            }

            Text {
                text: Settings.chunk-error == "" ? "OP_RETURN chunk size" : Settings.chunk-error;
                color: Settings.chunk-error == "" ? Theme.palette-muted : Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 14px;
            }
            HorizontalLayout {
                spacing: 6px;
                PillOption {
                    label: "Standard";
                    selected: Settings.chunk-mode == 0;
                    horizontal-stretch: 1;
                    tapped => { Settings.chunk-mode = 0; Callbacks.chunk-changed(); }
                }
                PillOption {
                    label: "80 compat";
                    selected: Settings.chunk-mode == 1;
                    horizontal-stretch: 1;
                    tapped => { Settings.chunk-mode = 1; Callbacks.chunk-changed(); }
                }
                PillOption {
                    label: "Custom";
                    selected: Settings.chunk-mode == 2;
                    horizontal-stretch: 1;
                    tapped => { Settings.chunk-mode = 2; Callbacks.chunk-changed(); }
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    height: 44px;
                    horizontal-stretch: 1;
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: chunk-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                    clip: true;
                    chunk-input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        text <=> Settings.chunk-text;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 18px;
                        single-line: true;
                        edited => {
                            Settings.chunk-mode = 2;
                            Callbacks.chunk-changed();
                        }
                        accepted => { self.clear-focus(); }
                    }
                }
                Text {
                    text: "bytes";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 16px;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "Chunk size caps each OP_RETURN output. Standard (100000) matches Bitcoin Core v30 relay defaults, verified on mempool.space; pick 80 if your broadcast endpoint rejects a note, then recompose it.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            // The wallet-context switcher (accounts) is a normal setting.
            SecondaryAction {
                width: 100%;
                text: "Accounts…";
                clicked => { Ui.screen = 21; }
            }

            // Spending wallet (funding-unification): an optional BIP-84
            // native-segwit wallet (same seed) that holds funds instead of
            // the notebook, scoped to the active (network, seed, account).
            Rectangle {
                height: 1px;
                background: Theme.palette-border;
            }
            Text {
                text: "Separate spending wallet";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
            }
            Text {
                text: "Fresh bc1q addresses hold your funds instead of the notebook — protects your balance and pubkey behind fresh-address hygiene. Costs a little more per note, and a shared spending pool publicly links the notes it pays for.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            HorizontalLayout {
                spacing: 8px;
                PillOption {
                    label: "Off";
                    selected: !Settings.spending-enabled;
                    horizontal-stretch: 1;
                    tapped => { Callbacks.set-spending-enabled(false); }
                }
                PillOption {
                    label: "On";
                    selected: Settings.spending-enabled;
                    horizontal-stretch: 1;
                    tapped => { Callbacks.set-spending-enabled(true); }
                }
            }
            if Settings.spending-enabled: VerticalLayout {
                spacing: 10px;
                Image {
                    source: Settings.spending-qr;
                    width: 150px;
                    height: 150px;
                    image-rendering: pixelated;
                    x: (parent.width - self.width) / 2;
                }
                Text {
                    text: Settings.spending-address;
                    color: Theme.palette-muted;
                    font-family: "SourceCodePro";
                    font-size: 12px;
                    wrap: char-wrap;
                    horizontal-alignment: center;
                }
                Text {
                    text: Settings.spending-balance-line;
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 17px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Next receive address, above. Paste every address below into the companion's \"Spending wallet addresses\" field so it can find this wallet's coins on the next sync — the companion otherwise only scans the notebook.";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Rectangle {
                    height: 76px;
                    background: Theme.palette-surface;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Theme.palette-border;
                    clip: true;
                    Flickable {
                        x: 10px;
                        y: 8px;
                        width: parent.width - 20px;
                        height: parent.height - 16px;
                        viewport-height: max(self.height, addr-text.preferred-height);
                        addr-text := Text {
                            width: parent.width;
                            text: Settings.spending-addresses-text == "" ? "No addresses used yet." : Settings.spending-addresses-text;
                            color: Theme.palette-muted;
                            font-family: "SourceCodePro";
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // ---- Dangerous area: reveal keys, grouped by risk ----
            // Recovery words + exports are all REVEALS; split by what a
            // captured value costs you — public (watch-only) vs private
            // (spends + decrypts). (Sal 2026-07-13.)
            Rectangle {
                height: 1px;
                background: Theme.palette-danger;
            }
            Text {
                text: "Dangerous area";
                color: Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 13px;
                font-weight: 700;
            }
            Text {
                text: "These show secrets on screen. Reveal only somewhere private — no cameras, no one watching over your shoulder.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            SecondaryAction {
                width: 100%;
                text: "Public keys…";
                disabled: !Recovery.seed-available;
                clicked => {
                    Callbacks.reveal-public();
                    Ui.screen = 23;
                }
            }
            Text {
                text: "Account xpub + descriptor. Watch-only — safe to share so someone can see this account's balance; can't spend or read private notes.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 12px;
                wrap: word-wrap;
            }
            SecondaryAction {
                width: 100%;
                text: "Private keys…";
                disabled: !Recovery.seed-available;
                clicked => {
                    Callbacks.reveal-private();
                    Ui.screen = 24;
                }
            }
            Text {
                text: "Recovery words + a notebook's raw key (hex/WIF). Anyone who sees these controls the coins and can read every private note. Keep them off cameras and out of sight.";
                color: Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 12px;
                wrap: word-wrap;
            }

                }
            }
        }

        // ----------------------------------------- screen 21: accounts
        // Wallet-context switcher only (rotation seed index + BIP-86
        // account). The words reveal lives on its own screen (22), reached
        // from a separate Settings entry.
        if Ui.screen == 21: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            ScreenHeader {
                title: "Accounts";
                back => { Ui.screen = 6; }
            }

            // Recovery seed — its own row with an explanation.
            Text {
                text: "Recovery seed";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
            }
            Text {
                text: "The 24-word phrase that backs up this wallet. Move to a fresh index only if a phrase is ever exposed — old words keep old keys, so sweep funds first.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            Rectangle {
                height: 44px;
                background: Theme.palette-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: seed-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                clip: true;
                seed-input := TextInput {
                    x: 14px;
                    width: parent.width - 28px;
                    height: 24px;
                    y: (parent.height - self.height) / 2;
                    text <=> Recovery.seed-text;
                    color: Theme.palette-foreground;
                    font-family: "SourceCodePro";
                    font-size: 18px;
                    single-line: true;
                    edited => { Recovery.saved-msg = ""; Recovery.context-error = ""; }
                    accepted => { self.clear-focus(); }
                }
            }

            // Account — its own row with an explanation.
            Text {
                text: "Account";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 15px;
                font-weight: 600;
            }
            Text {
                text: "A separate wallet under this seed — its own notebooks, coins, and addresses. Keep separate accounts for separate purposes.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            Rectangle {
                height: 44px;
                background: Theme.palette-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: account-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                clip: true;
                account-input := TextInput {
                    x: 14px;
                    width: parent.width - 28px;
                    height: 24px;
                    y: (parent.height - self.height) / 2;
                    text <=> Recovery.account-text;
                    color: Theme.palette-foreground;
                    font-family: "SourceCodePro";
                    font-size: 18px;
                    single-line: true;
                    edited => { Recovery.saved-msg = ""; Recovery.context-error = ""; }
                    accepted => { self.clear-focus(); }
                }
            }

            SecondaryAction {
                width: 100%;
                text: "Save";
                clicked => { Callbacks.set-context(); }
            }
            // Inline feedback: validation error (red) or the saved
            // confirmation (accent) — the Switch stays on this screen.
            if Recovery.context-error != "": Text {
                text: Recovery.context-error;
                color: Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }
            if Recovery.context-error == "" && Recovery.saved-msg != "": Text {
                text: Recovery.saved-msg;
                color: Theme.palette-primary;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            // The recovery-phrase backup lives on its own screen (22),
            // reached from a SEPARATE Settings entry — a pointer here so
            // the two tasks are clearly distinct.
            Text {
                text: "To back up or rotate a seed, use \"Private keys…\" in Settings — its Seed words show the 24-word phrase for the selected seed index.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ---------------------------------- screen 22: recovery words
        // Dedicated reveal, reached straight from Settings. Words/SeedQR
        // for the active seed; Back → Settings, clearing them
        // (reveal-close). Fits comfortably on its own, no scrolling.
        if Ui.screen == 22: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            ScreenHeader {
                title: "Recovery words";
                back => {
                    Callbacks.reveal-close();
                    Ui.screen = 6;
                }
            }

            Text {
                text: Recovery.title-line;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 16px;
                font-weight: 600;
            }

            if !Recovery.show-qr: HorizontalLayout {
                spacing: 16px;
                Text {
                    text: Recovery.words-col1;
                    color: Theme.palette-foreground;
                    font-family: "SourceCodePro";
                    font-size: 16px;
                    horizontal-stretch: 1;
                }
                Text {
                    text: Recovery.words-col2;
                    color: Theme.palette-foreground;
                    font-family: "SourceCodePro";
                    font-size: 16px;
                    horizontal-stretch: 1;
                }
            }
            if Recovery.show-qr: HorizontalLayout {
                alignment: center;
                Image {
                    source: Recovery.qr;
                    width: 220px;
                    height: 220px;
                    image-rendering: pixelated;
                }
            }

            SecondaryAction {
                width: 100%;
                text: Recovery.show-qr ? "Show words" : "Show as SeedQR";
                clicked => { Recovery.show-qr = !Recovery.show-qr; }
            }

            Text {
                text: "Write these down and keep them offline. Anyone who has them controls this seed's funds and can read its private notes.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ------------------------------------- screen 23: PUBLIC keys
        // Watch-only exports for the active account: xpub + tr() descriptor
        // (whole account, all addresses). Safe to share.
        if Ui.screen == 23: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 12px;

            ScreenHeader {
                title: "Public keys";
                back => {
                    Callbacks.export-close();
                    Ui.screen = 6;
                }
            }

            Text {
                text: Recovery.export-title;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 16px;
                font-weight: 600;
            }

            HorizontalLayout {
                spacing: 6px;
                PillOption {
                    label: "xpub";
                    selected: Recovery.export-which == 0;
                    horizontal-stretch: 1;
                    tapped => { Callbacks.export-select(0); }
                }
                PillOption {
                    label: "descriptor";
                    selected: Recovery.export-which == 1;
                    horizontal-stretch: 1;
                    tapped => { Callbacks.export-select(1); }
                }
            }

            Text {
                text: Recovery.export-label;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                font-weight: 600;
            }
            Rectangle {
                background: Theme.palette-surface;
                border-radius: 12px;
                border-width: 1px;
                border-color: Theme.palette-border;
                VerticalLayout {
                    padding: 12px;
                    Text {
                        text: Recovery.export-value;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 13px;
                        wrap: char-wrap;
                    }
                }
            }
            HorizontalLayout {
                alignment: center;
                Image {
                    source: Recovery.export-qr;
                    width: 176px;
                    height: 176px;
                    image-rendering: pixelated;
                }
            }
            Text {
                text: "Import into any wallet to WATCH this account — see its balance and public notes across all addresses. It cannot spend or read private notes. The descriptor also tells the wallet the script type + key origin.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 12px;
                wrap: word-wrap;
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ------------------------------------- screen 24: PRIVATE keys
        // The dangerous exports: recovery words (whole seed) and a single
        // notebook's raw key (hex/WIF). Camera warning up top.
        if Ui.screen == 24: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                title: "Private keys";
                back => {
                    Callbacks.export-close();
                    Ui.screen = 6;
                }
            }

            Text {
                text: Recovery.export-title;
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 16px;
                font-weight: 600;
            }
            Text {
                text: "Make sure no cameras or onlookers — anyone who captures these controls the coins and can read every private note.";
                color: Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 12px;
                font-weight: 600;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 6px;
                PillOption {
                    label: "Seed words";
                    selected: Recovery.export-seed-view;
                    horizontal-stretch: 1;
                    tapped => {
                        Recovery.export-seed-view = true;
                        Recovery.show-qr = false;
                    }
                }
                PillOption {
                    label: "hex";
                    selected: !Recovery.export-seed-view && Recovery.export-which == 2;
                    horizontal-stretch: 1;
                    tapped => {
                        Recovery.export-seed-view = false;
                        Callbacks.export-select(2);
                    }
                }
                PillOption {
                    label: "WIF";
                    selected: !Recovery.export-seed-view && Recovery.export-which == 3;
                    horizontal-stretch: 1;
                    tapped => {
                        Recovery.export-seed-view = false;
                        Callbacks.export-select(3);
                    }
                }
            }

            // --- Seed-words view (whole seed) ---
            if Recovery.export-seed-view: VerticalLayout {
                spacing: 10px;
                Text {
                    text: "24 words · backs up the whole seed";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 13px;
                }
                if !Recovery.show-qr: HorizontalLayout {
                    spacing: 16px;
                    Text {
                        text: Recovery.words-col1;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 15px;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: Recovery.words-col2;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 15px;
                        horizontal-stretch: 1;
                    }
                }
                if Recovery.show-qr: HorizontalLayout {
                    alignment: center;
                    Image {
                        source: Recovery.qr;
                        width: 200px;
                        height: 200px;
                        image-rendering: pixelated;
                    }
                }
                SecondaryAction {
                    width: 100%;
                    text: Recovery.show-qr ? "Show words" : "Show as SeedQR";
                    clicked => { Recovery.show-qr = !Recovery.show-qr; }
                }
                Text {
                    text: "These 24 words back up the WHOLE seed — every account and notebook. Import them into any taproot wallet, or write them down offline.";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            // --- Single-key view (one notebook: hex/WIF) ---
            if !Recovery.export-seed-view: VerticalLayout {
                spacing: 10px;
                Text {
                    text: "Notebook (whose private key):";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 13px;
                }
                for nb in Recovery.export-notebooks: Rectangle {
                    height: 40px;
                    background: nb.index == Recovery.export-nb-index ? Theme.palette-primary : Theme.palette-surface;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: nb.index == Recovery.export-nb-index ? Theme.palette-primary : Theme.palette-border;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        Text {
                            text: nb.name;
                            color: nb.index == Recovery.export-nb-index ? #ffffff : Theme.palette-foreground;
                            font-family: "Montserrat";
                            font-size: 14px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        Text {
                            text: nb.addr;
                            color: nb.index == Recovery.export-nb-index ? #ffffff : Theme.palette-muted;
                            font-family: "SourceCodePro";
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea { clicked => { Callbacks.export-pick-notebook(nb.index); } }
                }
                Text {
                    text: Recovery.export-label;
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 13px;
                    font-weight: 600;
                }
                Rectangle {
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Theme.palette-danger;
                    VerticalLayout {
                        padding: 12px;
                        Text {
                            text: Recovery.export-value;
                            color: Theme.palette-foreground;
                            font-family: "SourceCodePro";
                            font-size: 13px;
                            wrap: char-wrap;
                        }
                    }
                }
                HorizontalLayout {
                    alignment: center;
                    Image {
                        source: Recovery.export-qr;
                        width: 176px;
                        height: 176px;
                        image-rendering: pixelated;
                    }
                }
                Text {
                    text: "Just this one address's private key — import into chain-notes-app or any wallet to spend it. The whole account recovers from the Seed words instead.";
                    color: Theme.palette-muted;
                    font-family: "Montserrat";
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ---------------------------------- screen 25: Pay from (funding)
        // Two expandable coin lists — notebook (taproot) and spending
        // wallet (P2WPKH) — with independent per-coin selection. Selecting
        // coins from both sources at once is allowed (signed in one pass
        // via wpkh::sign_mixed_inputs) and flagged with a linkage warning.
        if Ui.screen == 25: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 8px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                vertical-stretch: 0;
                title: "Pay from";
                back => { Callbacks.funding-done(); Ui.screen = 3; }
            }

            if Funding.warning != "": Text {
                vertical-stretch: 0;
                text: Funding.warning;
                color: Theme.palette-danger;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-width: self.width;
                viewport-height: 44px * 2 + 60px
                    + Funding.notebook-coins.length * 56px
                    + Funding.spending-coins.length * 56px;
                VerticalLayout {
                    spacing: 10px;
                    Rectangle {
                        height: 44px;
                        TouchArea { clicked => { Funding.notebook-expanded = !Funding.notebook-expanded; } }
                        HorizontalLayout {
                            Text {
                                text: "Notebook";
                                color: Theme.palette-foreground;
                                font-family: "Montserrat";
                                font-size: 16px;
                                font-weight: 600;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: Funding.notebook-summary + (Funding.notebook-expanded ? " ^" : " v");
                                color: Theme.palette-muted;
                                font-family: "Montserrat";
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if Funding.notebook-expanded: VerticalLayout {
                        spacing: 6px;
                        for c in Funding.notebook-coins: FundingCoinEntry {
                            entry: c;
                            tapped => { Callbacks.funding-toggle-coin(c.key); }
                        }
                        if Funding.notebook-coins.length == 0: Text {
                            text: "No spendable notebook coins.";
                            color: Theme.palette-muted;
                            font-family: "Montserrat";
                            font-size: 13px;
                        }
                    }
                    Rectangle {
                        height: 44px;
                        TouchArea { clicked => { Funding.spending-expanded = !Funding.spending-expanded; } }
                        HorizontalLayout {
                            Text {
                                text: "Spending wallet";
                                color: Theme.palette-foreground;
                                font-family: "Montserrat";
                                font-size: 16px;
                                font-weight: 600;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: Funding.spending-summary + (Funding.spending-expanded ? " ^" : " v");
                                color: Theme.palette-muted;
                                font-family: "Montserrat";
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                    if Funding.spending-expanded: VerticalLayout {
                        spacing: 6px;
                        for c in Funding.spending-coins: FundingCoinEntry {
                            entry: c;
                            tapped => { Callbacks.funding-toggle-coin(c.key); }
                        }
                        if Funding.spending-coins.length == 0: Text {
                            text: Funding.spending-enabled
                                ? "No spending-wallet coins yet — fund its address and import a sync bundle."
                                : "Off — turn on \"Separate spending wallet\" in Settings first.";
                            color: Theme.palette-muted;
                            font-family: "Montserrat";
                            font-size: 13px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }

        // -------------------------------------------- screen 26: Change
        // Single-select destination for the compose in progress.
        if Ui.screen == 26: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 8px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                vertical-stretch: 0;
                title: "Change";
                back => { Callbacks.change-done(); Ui.screen = 3; }
            }

            ChangeOptionRow {
                vertical-stretch: 0;
                option-label: "Auto";
                sub: ChangePick.auto-label;
                selected: ChangePick.choice == "auto";
                tapped => { Callbacks.change-pick("auto"); }
            }
            ChangeOptionRow {
                vertical-stretch: 0;
                option-label: "Notebook address";
                sub: "Change returns to your notebook — the same address it goes to today.";
                selected: ChangePick.choice == "notebook";
                tapped => { Callbacks.change-pick("notebook"); }
            }
            ChangeOptionRow {
                vertical-stretch: 0;
                option-label: "Custom address…";
                sub: "";
                selected: ChangePick.choice == "custom";
                tapped => { Callbacks.change-pick("custom"); }
            }
            if ChangePick.choice == "custom": VerticalLayout {
                vertical-stretch: 0;
                spacing: 6px;
                Text {
                    text: ChangePick.custom-error == "" ? "Change address" : ChangePick.custom-error;
                    color: ChangePick.custom-error == "" ? Theme.palette-muted : Theme.palette-danger;
                    font-family: "Montserrat";
                    font-size: 13px;
                }
                Rectangle {
                    height: 44px;
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: change-addr-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                    clip: true;
                    change-addr-input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        text <=> ChangePick.custom-address;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 16px;
                        single-line: true;
                        edited => { Callbacks.change-address-changed(); }
                        accepted => { self.clear-focus(); }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }

        // ------------------------------------ screen 7: contacts (send-to)
        // The one input slot doubles as manual address entry and, when a
        // row's "name" zone was tapped, the contact-name editor. Errors go
        // in the label above the field so the keyboard can't hide them.
        if Ui.screen == 7: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 16px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 10px;

            ScreenHeader {
                vertical-stretch: 0;
                title: Contacts.pick-mode == "sweep" ? "Sweep to" : "Send to";
                back => {
                    if Contacts.pick-mode == "sweep" {
                        Contacts.pick-mode = "compose";
                        Ui.screen = 6;
                    } else {
                        Callbacks.refresh-home();
                        Ui.screen = 0;
                    }
                }
            }

            Text {
                vertical-stretch: 0;
                height: 18px;
                text: Contacts.input-error != "" ? Contacts.input-error
                    : Contacts.pick-mode == "sweep" ? "Destination address" : "Recipient address";
                color: Contacts.input-error != "" ? Theme.palette-danger : Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 14px;
                overflow: elide;
            }
            HorizontalLayout {
                vertical-stretch: 0;
                height: 44px;
                spacing: 8px;
                Rectangle {
                    height: 44px;
                    horizontal-stretch: 1;
                    background: Theme.palette-surface;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: contact-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                    clip: true;
                    contact-input := TextInput {
                        x: 14px;
                        width: parent.width - 28px;
                        height: 24px;
                        y: (parent.height - self.height) / 2;
                        text <=> Contacts.input-text;
                        color: Theme.palette-foreground;
                        font-family: "SourceCodePro";
                        font-size: 15px;
                        single-line: true;
                        edited => { Contacts.input-error = ""; }
                        // Keyboard "Done" blurs → KeyOS hides the keyboard.
                        accepted => { self.clear-focus(); }
                    }
                    Text {
                        x: 14px;
                        height: parent.height;
                        text: Contacts.input-text == "" && contact-input.preedit-text == ""
                            ? "Paste or type an address…" : "";
                        color: Theme.palette-muted;
                        font-family: "SourceCodePro";
                        font-size: 15px;
                        vertical-alignment: center;
                    }
                }
                // Fixed width so the address field gets the room.
                PillOption {
                    width: 72px;
                    label: "Use";
                    selected: true;
                    tapped => { Callbacks.pick-contact(Contacts.input-text); }
                }
            }

            // First and handiest option: the classic self-notebook note.
            // Hidden in sweep mode — sweep-to-self is the Coins screen's
            // consolidate, not a picker choice.
            if Contacts.pick-mode != "sweep": Rectangle {
                vertical-stretch: 0;
                height: 56px;
                border-radius: 12px;
                background: self-touch.has-hover ? Theme.palette-surface : transparent;
                border-width: 1px;
                border-color: Theme.palette-primary;
                self-touch := TouchArea { clicked => { Callbacks.pick-contact(""); } }
                VerticalLayout {
                    padding: 10px;
                    spacing: 2px;
                    Text {
                        text: "To: Self";
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 18px;
                        font-weight: 600;
                    }
                    Text {
                        text: "my notebook — this device's own address";
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 13px;
                    }
                }
            }

            SecondaryAction {
                vertical-stretch: 0;
                height: 52px;
                width: 100%;
                text: "Scan address QR";
                clicked => { Callbacks.scan-contact(); }
            }

            Text {
                vertical-stretch: 0;
                height: 16px;
                text: Contacts.rows.length > 0 ? "Recent"
                    : "Addresses you send to appear here.";
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: Contacts.rows.length * 72px;
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    for entry in Contacts.rows: ContactEntry {
                        entry: entry;
                        tapped => { Callbacks.pick-contact(entry.address); }
                        rename => {
                            Contacts.naming-address = entry.address;
                            Contacts.name-text = entry.name;
                            Contacts.naming-label = "Name for " + entry.meta;
                        }
                    }
                }
            }
        }

        // Naming dialog — modal over the contacts screen. Anchored near
        // the TOP so the on-screen keyboard never covers it; nested inside
        // the root container (sibling-app gotcha).
        // ------------------------------------ screen 20: notebooks (MAIN)
        // A notebook = an indexed identity; tapping a row opens its home
        // (screen 0). Boot lands here. Fresh install = empty list.
        if Ui.screen == 20: VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 24px;
            padding-right: 24px;
            padding-top: 24px + UISize.control-center-status-bar-height;
            padding-bottom: 24px;
            spacing: 14px;

            Text {
                text: "Chain Notes";
                color: Theme.palette-foreground;
                font-family: "Montserrat";
                font-size: 26px;
                font-weight: 700;
                horizontal-alignment: center;
            }

            PrimaryAction {
                width: 100%;
                text: "+  New notebook";
                clicked => { NotebookCb.create(); }
            }
            SecondaryAction {
                width: 100%;
                text: "Settings";
                clicked => { Callbacks.refresh-home(); Callbacks.funding-open(); Ui.screen = 6; }
            }

            if Ui.error != "": Text {
                text: Ui.error;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 13px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }

            if NotebooksUi.empty-line != "": Text {
                text: NotebooksUi.empty-line;
                color: Theme.palette-muted;
                font-family: "Montserrat";
                font-size: 15px;
                wrap: word-wrap;
                horizontal-alignment: center;
            }

            Flickable {
                vertical-stretch: 1;
                viewport-height: NotebooksUi.rows.length * 92px
                    + (NotebooksUi.archived-label != "" ? 44px : 0px)
                    + (NotebooksUi.show-archived ? NotebooksUi.archived-rows.length * 72px : 0px);
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    for nb in NotebooksUi.rows: Rectangle {
                        height: 84px;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: nb.active ? Theme.palette-primary : Theme.palette-border;
                        TouchArea { clicked => { NotebookCb.open(nb.account); } }
                        HorizontalLayout {
                            padding: 12px;
                            spacing: 8px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 4px;
                                alignment: center;
                                Text {
                                    text: nb.name;
                                    color: Theme.palette-foreground;
                                    font-family: "Montserrat";
                                    font-size: 18px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                Text {
                                    text: nb.meta;
                                    color: Theme.palette-muted;
                                    font-family: "SourceCodePro";
                                    font-size: 13px;
                                    overflow: elide;
                                }
                            }
                            // Rename
                            Rectangle {
                                width: 40px;
                                TouchArea { clicked => { NotebookCb.rename(nb.account); } }
                                Text {
                                    text: "Aa";
                                    color: Theme.palette-muted;
                                    font-family: "Montserrat";
                                    font-size: 15px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                            // Archive
                            Rectangle {
                                width: 40px;
                                TouchArea { clicked => { NotebookCb.archive(nb.account, true); } }
                                Text {
                                    text: "×";
                                    color: Theme.palette-muted;
                                    font-family: "Montserrat";
                                    font-size: 22px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                }
                            }
                        }
                    }
                    if NotebooksUi.archived-label != "": Rectangle {
                        height: 36px;
                        TouchArea { clicked => { NotebooksUi.show-archived = !NotebooksUi.show-archived; } }
                        Text {
                            text: NotebooksUi.archived-label + (NotebooksUi.show-archived ? "  ^" : "  v");
                            color: Theme.palette-muted;
                            font-family: "Montserrat";
                            font-size: 14px;
                            x: 4px;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    if NotebooksUi.show-archived: VerticalLayout {
                        spacing: 8px;
                        for nb in NotebooksUi.archived-rows: Rectangle {
                            height: 64px;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: Theme.palette-border;
                            HorizontalLayout {
                                padding: 12px;
                                spacing: 8px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    Text {
                                        text: nb.name;
                                        color: Theme.palette-muted;
                                        font-family: "Montserrat";
                                        font-size: 15px;
                                        overflow: elide;
                                    }
                                }
                                SecondaryAction {
                                    text: "Restore";
                                    clicked => { NotebookCb.archive(nb.account, false); }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ---- notebook name dialog (create + rename) ----
        if NotebooksUi.name-account != -1: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            TouchArea { }   // swallow taps outside the panel
            Rectangle {
                x: 24px;
                y: 90px + UISize.control-center-status-bar-height;
                width: parent.width - 48px;
                height: 176px;
                background: Theme.palette-surface;
                border-radius: 16px;
                border-width: 1px;
                border-color: Theme.palette-border;
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;
                    Text {
                        height: 20px;
                        text: NotebooksUi.name-account == -2 ? "Name your new notebook" : "Name this notebook";
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                    }
                    Rectangle {
                        height: 44px;
                        background: Theme.palette-background;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: nb-name-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                        clip: true;
                        nb-name-input := TextInput {
                            x: 14px;
                            width: parent.width - 28px;
                            height: 24px;
                            y: (parent.height - self.height) / 2;
                            text <=> NotebooksUi.name-text;
                            color: Theme.palette-foreground;
                            font-family: "Montserrat";
                            font-size: 16px;
                            single-line: true;
                            accepted => { self.clear-focus(); }
                        }
                        Text {
                            x: 14px;
                            height: parent.height;
                            text: NotebooksUi.name-text == "" && nb-name-input.preedit-text == ""
                                ? "Name (optional)" : "";
                            color: Theme.palette-muted;
                            font-family: "Montserrat";
                            font-size: 15px;
                            vertical-alignment: center;
                        }
                    }
                    HorizontalLayout {
                        height: 48px;
                        spacing: 8px;
                        SecondaryAction {
                            horizontal-stretch: 1;
                            text: "Cancel";
                            clicked => {
                                nb-name-input.clear-focus();
                                NotebookCb.name-cancel();
                            }
                        }
                        PrimaryAction {
                            horizontal-stretch: 1;
                            text: NotebooksUi.name-account == -2 ? "Create" : "Save";
                            clicked => {
                                nb-name-input.clear-focus();
                                NotebookCb.name-save();
                            }
                        }
                    }
                }
            }
        }

        if Contacts.naming-address != "": Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            TouchArea { }   // swallow taps outside the panel
            Rectangle {
                x: 24px;
                y: 90px + UISize.control-center-status-bar-height;
                width: parent.width - 48px;
                height: 176px;
                background: Theme.palette-surface;
                border-radius: 16px;
                border-width: 1px;
                border-color: Theme.palette-border;
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;
                    Text {
                        height: 20px;
                        text: Contacts.naming-label;
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                        overflow: elide;
                    }
                    Rectangle {
                        height: 44px;
                        background: Theme.palette-background;
                        border-radius: 12px;
                        border-width: 1px;
                        border-color: name-input.has-focus ? Theme.palette-primary : Theme.palette-border;
                        clip: true;
                        name-input := TextInput {
                            x: 14px;
                            width: parent.width - 28px;
                            height: 24px;
                            y: (parent.height - self.height) / 2;
                            text <=> Contacts.name-text;
                            color: Theme.palette-foreground;
                            font-family: "Montserrat";
                            font-size: 16px;
                            single-line: true;
                            // Keyboard "Done" blurs → keyboard hides.
                            accepted => { self.clear-focus(); }
                        }
                        Text {
                            x: 14px;
                            height: parent.height;
                            text: Contacts.name-text == "" && name-input.preedit-text == ""
                                ? "Contact name (empty to clear)" : "";
                            color: Theme.palette-muted;
                            font-family: "Montserrat";
                            font-size: 15px;
                            vertical-alignment: center;
                        }
                    }
                    HorizontalLayout {
                        height: 48px;
                        spacing: 8px;
                        SecondaryAction {
                            horizontal-stretch: 1;
                            text: "Cancel";
                            clicked => {
                                Contacts.naming-address = "";
                                Contacts.name-text = "";
                            }
                        }
                        PrimaryAction {
                            horizontal-stretch: 1;
                            text: "Save";
                            clicked => {
                                name-input.clear-focus();
                                Callbacks.save-contact-name();
                            }
                        }
                    }
                }
            }
        }

        // Note-too-large dialog — nested in root (sibling-app overlay gotcha).
        if Compose.show-oversize: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            TouchArea { }   // swallow taps outside the panel
            Rectangle {
                x: 24px;
                y: 90px + UISize.control-center-status-bar-height;
                width: parent.width - 48px;
                height: oversize-panel.preferred-height;
                background: Theme.palette-surface;
                border-radius: 16px;
                border-width: 1px;
                border-color: Theme.palette-border;
                oversize-panel := VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    Text {
                        text: "Note too large";
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                    }
                    Text {
                        text: Compose.oversize-message;
                        color: Theme.palette-muted;
                        font-family: "Montserrat";
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        SecondaryAction {
                            horizontal-stretch: 1;
                            text: Compose.oversize-offer-bump ? "Cancel" : "OK";
                            clicked => { Compose.show-oversize = false; }
                        }
                        if Compose.oversize-offer-bump: PrimaryAction {
                            horizontal-stretch: 1;
                            text: "Switch to Standard";
                            clicked => { Callbacks.oversize-bump(); }
                        }
                    }
                }
            }
        }

        // Sweep/consolidate confirm dialog — modal over screen 10, nested in
        // root (sibling-app overlay gotcha). Anchored near the top like the
        // other dialogs; the tx is already built + signed at this point.
        if Sweep.show-confirm: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            TouchArea { }   // swallow taps outside the panel
            Rectangle {
                x: 24px;
                y: 90px + UISize.control-center-status-bar-height;
                width: parent.width - 48px;
                height: sweep-confirm-panel.preferred-height;
                background: Theme.palette-surface;
                border-radius: 16px;
                border-width: 1px;
                border-color: Theme.palette-border;
                sweep-confirm-panel := VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    Text {
                        text: Sweep.kind == "consolidate" ? "Consolidate coins?" : "Sweep funds?";
                        color: Theme.palette-foreground;
                        font-family: "Montserrat";
                        font-size: 16px;
                        font-weight: 600;
                    }
                    Text {
                        text: Sweep.confirm-summary;
                        color: Theme.palette-muted;
                        font-family: "SourceCodePro";
                        font-size: 14px;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        SecondaryAction {
                            horizontal-stretch: 1;
                            text: "Cancel";
                            clicked => { Sweep.show-confirm = false; }
                        }
                        PrimaryAction {
                            horizontal-stretch: 1;
                            text: "Sign & export";
                            clicked => { Callbacks.sweep-sign(); }
                        }
                    }
                }
            }
        }

        // Busy overlay — nested inside the root container (never a direct
        // Window child; sibling-app gotcha).
        if Ui.busy: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000088;
            TouchArea { }
            Rectangle {
                width: 220px;
                height: 80px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: Theme.palette-surface;
                border-radius: 16px;
                Text {
                    text: "Working…";
                    color: Theme.palette-foreground;
                    font-family: "Montserrat";
                    font-size: 20px;
                    font-weight: 600;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }
    }
}
