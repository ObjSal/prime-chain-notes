// Globals shared between Rust and the UI. Screen map:
// 0 = home, 1 = notes list, 2 = note view, 3 = compose, 4 = confirm-sign,
// 5 = sync (actions: import/export), 6 = settings (network, chunk size),
// 7 = contacts (send-to picker: self / recents / scan / manual entry),
// 8 = signed external PSBT, 9 = coins (viewer-first UTXO list),
// 10 = sweep/consolidate (compose-like, shared via Sweep.kind),
// 20 = notebook list (the MAIN screen — boot lands here; a notebook =
//      an indexed identity, tapping a row opens its home = screen 0),
// 21 = accounts (wallet-context switcher), 22 = recovery words reveal,
// 23 = public-keys export, 24 = private-keys export (see Recovery below),
// 25 = Pay-from (funding-unification: notebook / spending-wallet coin
//      picker, reached from a compose nav row), 26 = Change (destination
//      picker for the compose in progress).

export global Ui {
    in-out property <int> screen: 0;
    in-out property <bool> busy: false;
    in-out property <string> error: "";
}

export global Home {
    // "" until the app seed is available (device locked / sim unprovisioned).
    in-out property <string> address: "";
    in-out property <image> qr;
    in-out property <string> balance-line: "";
    in-out property <string> sync-line: "never synced";
    in-out property <string> network: "mainnet";
}

export global Compose {
    in-out property <string> text: "";
    in-out property <bool> private-note: true;   // DECIDED: private by default
    // Directed note: non-empty = addressed to another address (dust
    // output); empty = classic self-note. Written ONLY by pick-contact
    // and the post-sign clear — compose itself has no address editing.
    in-out property <string> to-address: "";
    // Human line shown at the top of compose ("to: self — my notebook" /
    // "to: <name> (<short addr>)"), set by Rust at pick/sign time.
    in-out property <string> to-label: "";
    in-out property <int> tier: 1;               // 0 economy · 1 normal · 2 fast · 3 custom
    // sat/vB shown in the rate field. Rust refreshes it from the bundle's
    // tiers while tier < 3; a manual edit flips tier to 3 (custom) and the
    // field becomes the source of truth.
    in-out property <string> rate-text: "";
    // Bumped by Rust when the keyboard's Done key (which arrives as a
    // plain '\n' — the system keyboard has no distinct done signal) is
    // detected in the note text: the editor watches this and clears its
    // focus, which hides the keyboard. The newline itself is stripped.
    in-out property <int> dismiss-nonce: 0;
    // Gift amount (directed notes only): sats the recipient output carries
    // instead of the default dust. Default "330" (= DUST_LIMIT); a value
    // below dust is bumped back up to 330 on the Rust side. The collapsible
    // panel is shown only when this is a directed note (to-address != "").
    in-out property <string> gift-sats: "330";
    in-out property <bool> gift-expanded: false;
    in-out property <string> cost-line: "";
    in-out property <bool> can-continue: false;
    // "Note too large to broadcast" dialog (per-tx ~100 kB standardness wall).
    in-out property <bool> show-oversize: false;
    in-out property <bool> oversize-offer-bump: false; // true → offer Standard
    in-out property <string> oversize-message: "";

    // Pay-from (funding-unification, screen 25): compact nav row summary,
    // Rust-formatted from the current per-coin selection.
    in-out property <string> pay-from-label: "Notebook";     // "Notebook" | "Spending wallet" | "Mixed"
    in-out property <string> pay-from-balance: "";            // "12,340 sats · 3 coin(s)"
    // Change (screen 26): compact nav row summary.
    in-out property <string> change-label: "back to you";
}

export global Confirm {
    in-out property <string> summary: "";
}

// Universal "Confirm & sign" gate (screen 4) — one row per input/output,
// decoded from the ACTUAL signed (or, for an external PSBT pre-sign,
// unsigned) tx bytes by notes-core's `confirm::summarize_signed_tx`.
// `kind` mirrors title/subtitle/amount/kind row-for-row against
// `notes_core::confirm::SummaryRow`.
export struct ConfirmRow {
    title: string,
    subtitle: string,
    amount: string,
    kind: string,     // inputs: "input"; outputs: "note" | "recipient" | "self" | "change" | "other"
}

export global ConfirmSign {
    in-out property <[ConfirmRow]> inputs;
    in-out property <[ConfirmRow]> outputs;
    // Short caption above the txid, e.g. "Directed note · testnet4" or
    // "Sweep · mainnet - spends coins from 2 notebooks...".
    in-out property <string> context;
    in-out property <string> txid;
    // Public-note preview / "Private note (encrypted)" — "" hides the block.
    in-out property <string> note;
    in-out property <string> fee-line;
    // "" = no warning banner.
    in-out property <string> warn;
    // "compose" | "sweep" | "consolidate" | "psbt" — which sign body
    // `confirm-sign` dispatches to, and where `confirm-cancel` returns.
    in-out property <string> kind;
    in-out property <string> sign-label: "Sign & export";
}

export struct NoteRow {
    id: string,
    preview: string,
    meta: string,     // "pending" | "block 123 · 2 chunks" etc.
    badge: string,    // "PRIVATE" | "PUBLIC"
}

export struct SenderRow {
    key: string,      // raw sender key (address or "self") — the exclusion entry
    label: string,    // display: contact-less short address, or "Self"
    sub: string,      // "N note(s)"
    excluded: bool,
}

export global Notes {
    in-out property <[NoteRow]> rows;
    // Sender filter: exclusions persist per notebook; anything not listed
    // shows (a new sender is visible by default).
    in-out property <[SenderRow]> senders;
    in-out property <bool> filter-expanded: false;
    in-out property <string> hidden-label: "";   // "2 sender(s) hidden" | ""
}

export struct ContactRow {
    address: string,  // full address — the pick payload
    name: string,     // "" = unnamed
    label: string,    // name, or short address (Rust-formatted)
    meta: string,     // short address (Rust-formatted)
}

export global Contacts {
    // What a pick feeds: "compose" (default) sets the compose recipient;
    // "sweep" sets the sweep destination (the "To: Self" card is hidden —
    // sweep-to-self is the Coins screen's consolidate). Set by the screen
    // that opens the picker.
    in-out property <string> pick-mode: "compose";
    // Recency order, front = most recently used (no clock on-device).
    in-out property <[ContactRow]> rows;
    // Manual address entry.
    in-out property <string> input-text: "";
    // Validation error shown in the label ABOVE the field ("" = valid),
    // so the on-screen keyboard can never hide it (settings pattern).
    in-out property <string> input-error: "";
    // Naming dialog: non-empty naming-address shows the modal.
    in-out property <string> naming-address: "";
    in-out property <string> naming-label: "";   // "Name for <short addr>"
    in-out property <string> name-text: "";      // the name being edited
}

export global View {
    in-out property <string> id: "";
    in-out property <string> text: "";
    in-out property <string> meta: "";
    in-out property <string> badge: "";
    // Signed-tx QR (pending notes only): scan it with the companion page's
    // "Scan from device" camera to broadcast without any file transfer.
    in-out property <image> qr;
    in-out property <bool> has-qr: false;
    in-out property <bool> show-qr: false;
}

// A bundle file found in an inbox, for the import picker.
export struct BundleRow {
    name: string,     // file name
    label: string,    // "bundle.json · Internal" (Rust-formatted)
    loc: int,         // 0 = Internal, 1 = Airlock (matches the pick callback)
}

export global Sync {
    in-out property <string> status: "";
    in-out property <string> result: "";
    // Import picker: tapping "Import sync bundle" lists what's actually in
    // the inboxes so the user picks a file (instead of a silent auto-pick).
    in-out property <bool> picking: false;
    in-out property <[BundleRow]> bundles;
    // Shown in the picker when no bundle files were found — tells the user
    // where to put one.
    in-out property <string> empty-hint: "";
}

// Signing an external transaction (PSBT) for a wallet whose coins fund a note
// composed on the desktop peer — and the shared "Signed" hand-off screen the
// sweep/consolidate flow reuses (summary + broadcast QR + Done). Screen 8.
export global SignPsbt {
    in-out property <string> summary: "";
    in-out property <image> qr;
    in-out property <bool> has-qr: false;
    // Where Back returns to: 5 (sync) for external PSBTs, 0 (home) after a
    // sweep/consolidate — money flows return home.
    in-out property <int> back-screen: 5;
}

export struct CoinRow {
    label: string,    // "12345 sats"
    meta: string,     // "txid ab12cd34…9f · output 0"
}

// Screen 9 — viewer-first coins list: the UTXO ledger as of the last sync
// bundle, with ONE action (consolidate) opening the shared sweep screen.
export global Coins {
    in-out property <[CoinRow]> rows;
    in-out property <string> summary: "";   // "3 coins · 45000 sats"
    in-out property <bool> can-consolidate: false; // 2+ coins
}

// Screen 10 — compose-like sweep/consolidate flow, shared via `kind`.
// Destination comes from the picker (sweep) or is self (consolidate);
// the screen itself has no address editing, like compose.
export global Sweep {
    in-out property <string> kind: "sweep";  // "sweep" | "consolidate"
    in-out property <string> dest: "";       // "" = self (consolidate)
    in-out property <string> dest-label: "";
    in-out property <int> tier: 1;           // 0 economy · 1 normal · 2 fast · 3 custom
    in-out property <string> rate-text: "";
    in-out property <string> inputs-line: ""; // "Inputs · 3 coins · 45000 sats (all)"
    in-out property <string> cost-line: "";
    in-out property <bool> can-continue: false;
}

export global Settings {
    // OP_RETURN chunk-size: 0 standard (100000, Core v30 relay default) ·
    // 1 compat-80 · 2 custom. Purely device-side — bundles carry no relay
    // policy. The bytes field mirrors the effective size; editing flips to
    // custom (valid range 20–100000).
    in-out property <int> chunk-mode: 0;
    in-out property <string> chunk-text: "";
    // Inline validation error for the chunk field ("" = valid) — shown in
    // the section label so the on-screen keyboard can't hide it.
    in-out property <string> chunk-error: "";

    // Spending wallet (funding-unification): "Separate spending wallet"
    // toggle + card, scoped to the active (network, seed, account) context.
    in-out property <bool> spending-enabled: false;
    in-out property <string> spending-balance-line: "";   // "5,000 sats · 1 coin"
    in-out property <string> spending-address: "";         // next unused receive address
    in-out property <image> spending-qr;
    // Every used address, one per line "chain/index  address" — copy this
    // into the companion's "Spending wallet addresses" field so it can
    // include the spending wallet's coins in the next sync bundle (the
    // companion otherwise only scans the notebook address).
    in-out property <string> spending-addresses-text: "";
}

// One coin on the Pay-from screen (screen 25) — a notebook OR spending-
// wallet UTXO with a stable key for the toggle callback.
export struct FundingCoinRow {
    key: string,      // "notebook:<txid>:<vout>" | "spending:<txid>:<vout>"
    label: string,    // "12,345 sats"
    meta: string,     // "txid ab12…9f · output 0" (+ " · idx 3" for spending)
    selected: bool,
}

// Screen 25 — Pay-from: two expandable coin lists (notebook / spending
// wallet), independent per-coin selection; a mixed selection (coins from
// both) is allowed (`wpkh::sign_mixed_inputs`) and shown a linkage warning.
export global Funding {
    in-out property <[FundingCoinRow]> notebook-coins;
    in-out property <[FundingCoinRow]> spending-coins;
    in-out property <string> notebook-summary;   // "3 coin(s) · 12,340 sats"
    in-out property <string> spending-summary;   // "1 coin · 5,000 sats" | "Off" | "No coins"
    in-out property <bool> spending-enabled;
    in-out property <bool> notebook-expanded: true;
    in-out property <bool> spending-expanded: false;
    // Non-empty = at least one coin from each source is selected — shown
    // as a linkage warning line under the lists.
    in-out property <string> warning: "";
}

// Screen 26 — Change: single-select destination for the compose in
// progress. "auto" resolves in Rust to a fresh spending address (when the
// current Pay-from selection includes a spending coin) or the notebook
// address otherwise; "custom" reveals the address field.
export global ChangePick {
    in-out property <string> choice: "auto";      // "auto" | "notebook" | "custom"
    in-out property <string> auto-label: "";       // "Fresh spending-wallet address" | "Notebook address"
    in-out property <string> custom-address: "";
    in-out property <string> custom-error: "";
}

// Recovery seeds (screen 21 + the Settings wallet-context section).
// A seed index rotates the whole 24-word phrase (scoped compromise);
// the account is the BIP-86 wallet context — together they pick which
// bip86 notebooks are visible (legacy notebooks are context-free).
// Export-keys notebook picker row (screen 23, hex/WIF only): which
// receive index's private key to export, labeled by notebook name + addr.
export struct ExportNbRow {
    index: int,       // BIP-86 receive index (the hex/WIF selector)
    name: string,
    addr: string,     // short address
}

export global Recovery {
    // True when GetAppSeed returned (set once at boot) — gates the reveal
    // independently of whether a notebook is open (the recovery flow is
    // wallet-level: reached from the list-level Settings, no active
    // notebook, so Home.address is empty and must NOT gate this).
    in-out property <bool> seed-available: false;
    // Settings fields (numeric, committed by the Switch action).
    in-out property <string> seed-text: "0";
    in-out property <string> account-text: "0";
    // Validation error shown under the fields ("" = valid).
    in-out property <string> context-error: "";
    // Success confirmation after a Switch ("Saved · seed N · account M"),
    // cleared when the user edits a field.
    in-out property <string> saved-msg: "";
    // Reveal screen content — set on reveal, CLEARED on close.
    in-out property <string> title-line: "";
    in-out property <string> words-col1: "";   // "1. word\n… 12. word"
    in-out property <string> words-col2: "";   // "13. word\n… 24. word"
    in-out property <image> qr;
    in-out property <bool> show-qr: false;

    // Export-keys screen (23): the active context's importable formats.
    // Account-level xpub/descriptor (all this account's notebooks) plus
    // index-0 hex/WIF (a single-key import). The private xprv is
    // deliberately NOT exported on the device — the 24 words already
    // recover the whole seed (PLAN-chain-notes-seed-rotation.md).
    in-out property <string> export-title: "";   // "Seed N · account M · index 0"
    in-out property <string> export-xpub: "";
    in-out property <string> export-descriptor: "";
    in-out property <string> export-hex: "";
    in-out property <string> export-wif: "";
    in-out property <int> export-which: 0;       // 0 xpub · 1 desc · 2 hex · 3 wif
    in-out property <string> export-label: "";   // the selected format's label
    in-out property <string> export-value: "";   // the selected format's value
    in-out property <image> export-qr;
    // Notebook picker (hex/WIF only): the active account's notebooks and
    // which receive index is selected for the single-key export.
    in-out property <[ExportNbRow]> export-notebooks;
    in-out property <int> export-nb-index: 0;
    in-out property <string> export-nb-name: "";   // selected notebook's name (for the label)
    // Private-keys screen: the "Seed words" pill shows the 24 words (+
    // SeedQR) instead of a single-key value box.
    in-out property <bool> export-seed-view: false;
}

export struct NotebookRow {
    account: int,
    name: string,
    meta: string,     // "addr-short · N notes" (device has no live balance)
    active: bool,
}

// Screen 20 — the notebook list (main screen). A notebook = an indexed
// identity; tapping a row opens its home (screen 0).
export global NotebooksUi {
    in-out property <[NotebookRow]> rows;
    in-out property <[NotebookRow]> archived-rows;
    in-out property <string> archived-label: "";   // "Archived (2)" | ""
    in-out property <bool> show-archived: false;
    in-out property <string> empty-line: "";        // shown when no active notebooks
    // Per-notebook home (screen 0) header title = the open notebook's name.
    in-out property <string> title: "Chain Notes";
    // Name dialog: -1 closed · -2 create (next account) · >=0 rename that account.
    in-out property <int> name-account: -1;
    in-out property <string> name-text: "";
}

export global NotebookCb {
    callback open(int);          // open a notebook (account) → its home (screen 0)
    callback create();           // open the name dialog in create mode
    callback name-save();        // create/rename commit
    callback name-cancel();
    callback rename(int);        // open the name dialog for an existing account
    callback archive(int, bool); // archive / restore
    callback back-to-list();     // per-notebook home → the list
}

export global Callbacks {
    callback refresh-home();
    callback compose-changed();     // every keystroke / toggle / tier change
    callback compose-continue();    // build + sign, then screen 4
    callback oversize-bump();       // raise chunk size to Standard from the dialog
    // Universal Confirm & sign gate (screen 4), dispatched on ConfirmSign.kind:
    // "compose" persists + exports then note view; "sweep"/"consolidate"
    // persists the wallet ledger + exports then screen 8; "psbt" signs the
    // stashed external PSBT then screen 8.
    callback confirm-sign();
    callback confirm-cancel();      // Back from screen 4 — discard + return to the origin screen
    callback refresh-notes();
    callback toggle-sender(string, bool);  // exclude/include a sender key
    callback open-note(string);     // note id (hex)
    callback import-bundle();       // (legacy: auto-pick first inbox bundle)
    callback list-bundles();        // scan inboxes → Sync.bundles, open picker
    callback pick-bundle(string, int); // import a chosen file (name, loc 0/1)
    callback scan-bundle();         // system QR scanner → bundle import
    callback export-pending();
    callback sign-psbt();           // system QR scanner → sign our inputs → screen 8
    callback cycle-network();       // mainnet → testnet4 → signet → regtest → …
    callback chunk-changed();       // chunk-mode pill tapped / bytes field edited
    callback refresh-contacts();    // rebuild Contacts.rows from state
    callback pick-contact(string);  // "" = self; the single funnel: validate,
                                    // bump recency, set Compose.to-*, → screen 3
    callback scan-contact();        // system QR scanner → upsert (unnamed) + pick
    callback save-contact-name();   // reads Contacts.naming-address + input-text
    callback refresh-coins();       // rebuild Coins.rows from the UTXO ledger
    callback consolidate-open();    // Coins → sweep screen with kind=consolidate
    callback sweep-changed();       // tier pill / custom rate edited → reprice
    callback sweep-continue();      // build + sign, then the universal confirm screen (4)
    callback reveal-seed();         // derive the active seed's words → screen 21
    callback reveal-close();        // clear the words + QR, back to settings
    callback set-context();         // commit Recovery.seed-text/account-text
    callback reveal-public();       // derive account xpub + descriptor → screen 23
    callback reveal-private();      // derive recovery words + notebook hex/WIF → screen 24
    callback export-close();        // clear the exports, back to settings
    callback export-select(int);    // switch shown format (0 xpub · 1 desc · 2 hex · 3 wif)
    callback export-pick-notebook(int);  // hex/WIF: pick which receive index to export

    // Spending wallet (funding-unification).
    callback set-spending-enabled(bool);  // Settings toggle
    callback funding-open();              // compose's "Pay from" row → screen 25
    callback funding-toggle-coin(string); // coin key (source:txid:vout)
    callback funding-done();              // Back from screen 25 → recompute + screen 3
    callback change-open();               // compose's "Change" row → screen 26
    callback change-pick(string);         // "auto" | "notebook" | "custom"
    callback change-address-changed();    // custom-address field edited
    callback change-done();               // Back from screen 26 → recompute + screen 3
}
