// Globals shared between Rust and the UI. Screen map:
// 0 = home, 1 = notes list, 2 = note view, 3 = compose, 4 = confirm-sign,
// 5 = sync (actions: import/export), 6 = settings (network, chunk size).

export global Ui {
    in-out property <int> screen: 0;
    in-out property <bool> busy: false;
    in-out property <string> error: "";
}

export global Home {
    // "" until the app seed is available (device locked / sim unprovisioned).
    in-out property <string> address: "";
    in-out property <image> qr;
    in-out property <string> balance-line: "";
    in-out property <string> sync-line: "never synced";
    in-out property <string> network: "mainnet";
}

export global Compose {
    in-out property <string> text: "";
    in-out property <bool> private-note: true;   // DECIDED: private by default
    in-out property <int> tier: 1;               // 0 economy · 1 normal · 2 fast · 3 custom
    // sat/vB shown in the rate field. Rust refreshes it from the bundle's
    // tiers while tier < 3; a manual edit flips tier to 3 (custom) and the
    // field becomes the source of truth.
    in-out property <string> rate-text: "";
    in-out property <string> cost-line: "";
    in-out property <bool> can-continue: false;
}

export global Confirm {
    in-out property <string> summary: "";
}

export struct NoteRow {
    id: string,
    preview: string,
    meta: string,     // "pending" | "block 123 · 2 chunks" etc.
    badge: string,    // "PRIVATE" | "PUBLIC"
}

export global Notes {
    in-out property <[NoteRow]> rows;
}

export global View {
    in-out property <string> id: "";
    in-out property <string> text: "";
    in-out property <string> meta: "";
    in-out property <string> badge: "";
}

export global Sync {
    in-out property <string> status: "";
    in-out property <string> result: "";
}

export global Settings {
    // OP_RETURN chunk-size policy: 0 auto (bundle) · 1 compat-80 · 2 custom.
    // The bytes field mirrors the effective size; editing it flips to
    // custom. Custom may never exceed the bundle's max_op_return_bytes.
    in-out property <int> chunk-mode: 0;
    in-out property <string> chunk-text: "";
    // Inline validation error for the chunk field ("" = valid) — shown in
    // the section label so the on-screen keyboard can't hide it.
    in-out property <string> chunk-error: "";
}

export global Callbacks {
    callback refresh-home();
    callback compose-changed();     // every keystroke / toggle / tier change
    callback compose-continue();    // build + sign, then screen 4
    callback confirm-sign();        // persist + export, then note view
    callback refresh-notes();
    callback open-note(string);     // note id (hex)
    callback import-bundle();
    callback export-pending();
    callback cycle-network();       // mainnet → signet → regtest → mainnet
    callback chunk-changed();       // chunk-mode pill tapped / bytes field edited
}
